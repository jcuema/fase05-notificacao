APP_NAME="Notificacao"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=notificacao
DB_USERNAME=notificacao
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
CACHE_STORE=database
QUEUE_CONNECTION=sync

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Exchange de entrada (publicado pelo gerenciamento-video)
NOTIFICATION_EXCHANGE=video_notification_exchange

# Filas de auditoria de saída
NOTIFICATION_QUEUE_SENT=notification_message_sent
NOTIFICATION_QUEUE_DELIVERED=notification_message_delivered
NOTIFICATION_QUEUE_FAILED=notification_message_failed

# SMTP — use Mailpit em desenvolvimento (http://localhost:8025)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@fase05.local"
MAIL_FROM_NAME="Plataforma de Vídeo"

VITE_APP_NAME="${APP_NAME}"
